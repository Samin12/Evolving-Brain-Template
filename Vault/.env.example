# Vault/.env.example
#
# Template for Vault/.env — the real values file.
# Copy this to Vault/.env and fill in. Never commit .env.
#
# Every key listed here must also appear in Vault/key-inventory.md
# with a description of what it's for and which workflows/projects use it.

# === Anthropic / Claude ===
ANTHROPIC_API_KEY=

# === GitHub ===
GITHUB_TOKEN=

# === Processing / connectors ===
# Add keys for each connector as you wire them up.
# Example:
# HEPTABASE_API_KEY=
# OPENAI_API_KEY=
# GRANOLA_API_KEY=
# GMAIL_OAUTH_REFRESH_TOKEN=
